    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nuxt": "^4.4.2",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^5.9.3",
    "vue": "^3.5.30",
    "vue-router": "4",
